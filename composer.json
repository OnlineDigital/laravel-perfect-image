{
    "name": "onlinedigital/laravel-perfect-image",
    "description": "Automatic responsive image optimization for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OnlineDigital\\PerfectImage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OnlineDigital\\PerfectImage\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OnlineDigital\\PerfectImage\\PerfectImageServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
